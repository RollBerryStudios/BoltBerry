<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- BB-047: prefer the narrower allow-jit entitlement. allow-unsigned-
       executable-memory permits *any* unsigned executable page; allow-jit
       only permits memory marked as JIT (which is what V8 actually needs).
       Hardened Runtime is happier with this and Apple's notarisation
       guidance recommends it. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
