{
  "name": "boltberry",
  "version": "0.20.19",
  "description": "BoltBerry \u2013 Lokale Virtual-Tabletop-App f\u00fcr Pen-and-Paper-Runden",
  "main": "dist/main/index.js",
  "homepage": ".",
  "author": {
    "name": "RollBerry Studios",
    "email": "rollberry@proton.me"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n main,preload,renderer,electron \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:preload": "node scripts/build-preload.mjs --watch",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:electron": "wait-on http://localhost:5173 && electronmon .",
    "build": "npm run build:main && npm run typecheck:preload && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "typecheck:preload": "tsc -p tsconfig.preload.json --noEmit",
    "build:preload": "node scripts/build-preload.mjs",
    "build:renderer": "vite build --config vite.config.ts",
    "electron": "electron .",
    "start": "npm run build && npm run check:bundle && npm run electron",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && npm run check:bundle && electron-builder",
    "dist:win": "npm run build && npm run check:bundle && electron-builder --win",
    "dist:mac": "npm run build && npm run check:bundle && electron-builder --mac",
    "dist:linux": "npm run build && npm run check:bundle && electron-builder --linux",
    "test": "vitest run",
    "check:bundle": "node scripts/check-player-bundle.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:all": "npm test && npm run check:bundle && npm run check:i18n",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "archiver-utils": "^5.0.2",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.3",
    "immer": "^10.1.1",
    "konva": "^9.3.6",
    "pdfjs-dist": "^4.4.168",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.7",
    "react-i18next": "^17.0.2",
    "react-konva": "^18.2.10",
    "react-konva-utils": "^2.0.0",
    "unzipper": "^0.12.3",
    "use-immer": "^0.11.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.44.0",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/unzipper": "^0.10.11",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "electron-devtools-installer": "^3.2.0",
    "electronmon": "^2.0.4",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "wait-on": "^9.0.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0"
  }
}