    "en": [
      {
        "name": "Charge",
        "text": "If the centaur moves at least 30 ft. straight toward a target and then hits it with a pike attack on the same turn, the target takes an extra 10 (3d6) piercing damage."
      }
    ],
    "de": [
      {
        "name": "Sturmangriff",
        "text": "Wenn der Zentaur sich mindestens neun Meter weit in gerader Linie auf ein Ziel zubewegt und es dann im selben Zug mit einem Pikenangriff trifft, erleidet das Ziel zusätzlich 10 (3W6) Stichschaden."
      }
    ]
  },
  "actions": {
    "en": [
      {
        "name": "Multiattack",
        "text": "The centaur makes two attacks: one with its pike and one with its hooves or two with its longbow."
      },
      {
        "name": "Pike",
        "text": "Melee Weapon Attack: +6 to hit, reach 10 ft., one target. Hit: 9 (1d10 + 4) piercing damage."
      },
      {
        "name": "Hooves",
        "text": "Melee Weapon Attack: +6 to hit, reach 5 ft., one target. Hit: 11 (2d6 + 4) bludgeoning damage."
      },
      {
        "name": "Longbow",
        "text": "Ranged Weapon Attack: +4 to hit, range 150/600 ft., one target. Hit: 6 (1d8 + 2) piercing damage."
      }
    ],
    "de": [
      {
        "name": "Mehrfachangriff",
        "text": "Zentauren führen zwei Angriffe aus: entweder einen mit dem Spieß und einen mit den Hufen oder zwei mit dem Langbogen."
      },
      {
        "name": "Hufe",
        "text": "Nahkampfwaffenangriff: +6 auf Treffer, Reichweite 1,5 m, ein Ziel. Treffer: 11 (2W6+4) Wuchtschaden."
      },
      {
        "name": "Pike",
        "text": "Nahkampfwaffenangriff: +6 auf Treffer, Reichweite 3 m, ein Ziel. Treffer: 9 (1W10+4) Stichschaden."
      },
      {
        "name": "Langbogen",
        "text": "Fernkampfwaffenangriff: +4 auf Treffer, Reichweite 45/180 m, ein Ziel. Treffer: 6 (1W8+2) Stichschaden."
      }
    ]
  },
