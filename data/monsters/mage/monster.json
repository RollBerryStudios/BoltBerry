  "traits": {
    "en": [
      {
        "name": "Spellcasting",
        "text": "The mage is a 9th-level spellcaster. Its spellcasting ability is Intelligence (spell save DC 14, +6 to hit with spell attacks). The mage has the following wizard spells prepared:"
      },
      {
        "name": "Cantrips (at will)",
        "text": "fire bolt, light, mage hand, prestidigitation"
      },
      {
        "name": "1st level (4 slots)",
        "text": "detect magic, mage armor, magic missile, shield"
      },
      {
        "name": "2nd level (3 slots)",
        "text": "misty step, suggestion"
      },
      {
        "name": "3rd level (3 slots)",
        "text": "counterspell, fireball, fly"
      },
      {
        "name": "4th level (3 slots)",
        "text": "greater invisibility, ice storm"
      },
      {
        "name": "5th level (1 slot)",
        "text": "cone of cold"
      }
    ],
    "de": [
      {
        "name": "Zaubern",
        "text": "Der Magier ist ein Zauberwirker des 9. Grades. Seine Zauberfertigkeit ist Intelligenz (Zauberrettungswurf SG 14, +6 zum Treffen mit Zauberangriffen). Der Magier hat die folgenden Zaubersprüche vorbereitet:"
      },
      {
        "name": "Zaubertricks (nach Belieben)",
        "text": "Feuerpfeil, Licht, Magierhand, Taschenspielerei"
      },
      {
        "name": "1. Grad (4 Zauberplätze)",
        "text": "Magie entdecken, Magierrüstung, Magisches Geschoss, Schild"
      },
      {
        "name": "2. Grad (3 Zauberplätze)",
        "text": "Nebelschritt, Einflüsterung"
      },
      {
        "name": "3. Grad (3 Zauberplätze)",
        "text": "Gegenzauber, Feuerball, Fliegen"
      },
      {
        "name": "4. Grad (3 Zauberplätze)",
        "text": "Mächtige Unsichtbarkeit, Eissturm"
      },
      {
        "name": "5th level (1 Zauberplatz)",
        "text": "Kältekegel"
      }
    ]
  },
  "actions": {
    "en": [
      {
        "name": "Dagger",
        "text": "Melee or Ranged Weapon Attack: +5 to hit, reach 5 ft. or range 20/60 ft., one target. Hit: 4 (1d4 + 2) piercing damage."
      }
    ],
    "de": [
