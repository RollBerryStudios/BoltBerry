        "name": "Invisibility",
        "text": "The stalker is invisible."
      },
      {
        "name": "Faultless Tracker",
        "text": "The stalker is given a quarry by its summoner. The stalker knows the direction and distance to its quarry as long as the two of them are on the same plane of existence. The stalker also knows the location of its summoner."
      }
    ],
    "de": [
      {
        "name": "Einwandfreier Fährtenleser",
        "text": "Der Beschwörer weist dem Pirscher eine Beute zu. Der Pirscher kennt die Richtung und Entfernung zu seiner Beute, solange die beiden sich auf der gleichen Existenzebene befinden. Der Pirscher weiß auch, wo sich sein Beschwörer befindet."
      },
      {
        "name": "Unsichtbarkeit",
        "text": "Der Pirscher ist unsichtbar."
      }
    ]
  },
