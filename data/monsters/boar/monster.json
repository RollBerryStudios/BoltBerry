  "traits": {
    "en": [
      {
        "name": "Charge",
        "text": "If the boar moves at least 20 ft. straight toward a target and then hits it with a tusk attack on the same turn, the target takes an extra 3 (1d6) slashing damage. If the target is a creature, it must succeed on a DC 11 Strength saving throw or be knocked prone."
      },
      {
        "name": "Relentless",
        "text": "If the boar takes 7 damage or less that would reduce it to 0 hit points, it is reduced to 1 hit point instead."
      }
    ],
    "de": [
      {
        "name": "Sturmangriff",
        "text": "Wenn der Eber sich mindestens sechs Meter weit direkt auf ein Ziel zubewegt und es dann im selben Zug mit einem Hauerangriff trifft, erleidet das Ziel zusätzlich 3 (1W6) Hiebschaden. Wenn das Ziel eine Kreatur ist, muss es einen SG-11-Stärkerettungswurf bestehen, oder es wird umgestoßen."
      },
      {
        "name": "Unermüdlich (wird nach kurzer oder langer Rast aufgeladen)",
        "text": "Wenn der Eber maximal 7 Schaden erleidet und seine Trefferpunkte dadurch auf 0 sinken würden, hat er stattdessen noch 1 Trefferpunkt."
      }
    ]
  },
  "actions": {
    "en": [
      {
        "name": "Tusk",
        "text": "Melee Weapon Attack: +3 to hit, reach 5 ft., one target. Hit: 4 (1d6 + 1) slashing damage."
      }
    ],
    "de": [
      {
        "name": "Hauer",
        "text": "Nahkampfwaffenangriff: +3 auf Treffer, Reichweite 1,5 m, ein Ziel. Treffer: 4 (1W6+1) Hiebschaden."
      }
    ]
  },
