  "traits": {
    "en": [
      {
        "name": "Trampling Charge",
        "text": "If the elephant moves at least 20 ft. straight toward a creature and then hits it with a gore attack on the same turn, that target must succeed on a DC 12 Strength saving throw or be knocked prone. If the target is prone, the elephant can make one stomp attack against it as a bonus action."
      }
    ],
    "de": [
      {
        "name": "Trampel-Sturmangriff",
        "text": "Wenn der Elefant sich mindestens sechs Meter weit direkt auf eine Kreatur zubewegt und sie dann im selben Zug mit einem Zerfleischen-Angriff trifft, muss das Ziel einen SG-12-Stärkerettungswurf bestehen, oder es wird umgestoßen. Gegen ein liegendes Ziel kann der Elefant als Bonusaktion einen Stampfen-Angriff ausführen."
      }
    ]
  },
  "actions": {
    "en": [
      {
        "name": "Gore",
        "text": "Melee Weapon Attack: +8 to hit, reach 5 ft., one target. Hit: 19 (3d8 + 6) piercing damage."
      },
      {
        "name": "Stomp",
        "text": "Melee Weapon Attack: +8 to hit, reach 5 ft., one prone creature. Hit: 22 (3d10 + 6) bludgeoning damage."
      }
    ],
    "de": [
      {
        "name": "Stampfen",
        "text": "Nahkampfwaffenangriff: +8 auf Treffer, Reichweite 1,5 m, eine liegende Kreatur. Treffer: 22 (3W10+6) Wuchtschaden."
      },
      {
        "name": "Zerfleischen",
        "text": "Nahkampfwaffenangriff: +8 auf Treffer, Reichweite 1,5 m, ein Ziel. Treffer: 19 (3W8+6) Stichschaden."
      }
    ]
  },
