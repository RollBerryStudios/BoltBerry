    "en": [
      {
        "name": "Parry",
        "text": "The noble adds 2 to its AC against one melee attack that would hit it. To do so, the noble must see the attacker and be wielding a melee weapon."
      }
    ],
    "de": [
      {
        "name": "Parieren",
        "text": "Der Adelige erhöht seine RK gegen einen Nahkampfangriff, der treffen würde, um 2. Dazu muss der Adelige den Angreifer sehen können und eine Nahkampfwaffe führen."
      }
    ]
