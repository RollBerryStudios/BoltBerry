  "traits": {
    "en": [
      {
        "name": "Pack Tactics",
        "text": "The thug has advantage on an attack roll against a creature if at least one of the thug's allies is within 5 ft. of the creature and the ally isn't incapacitated."
      }
    ],
    "de": [
      {
        "name": "Rudeltaktik",
        "text": "Der Schläger ist bei Angriffswürfen gegen eine Kreatur im Vorteil, wenn sich mindestens einer seiner Verbündeten, der nicht kampfunfähig ist, im Abstand von bis zu 1,5 Metern von der Kreatur befindet."
      }
    ]
  },
  "actions": {
    "en": [
      {
        "name": "Multiattack",
        "text": "The thug makes two melee attacks."
      },
      {
        "name": "Mace",
        "text": "Melee Weapon Attack: +4 to hit, reach 5 ft., one creature. Hit: 5 (1d6 + 2) bludgeoning damage."
      },
      {
        "name": "Heavy Crossbow",
        "text": "Ranged Weapon Attack: +2 to hit, range 100/400 ft., one target. Hit: 5 (1d10) piercing damage."
      }
    ],
    "de": [
      {
        "name": "Mehrfachangriff",
        "text": "Der Schläger führt zwei Nahkampfangriffe aus."
      },
      {
        "name": "Streitkolben",
        "text": "Nahkampfwaffenangriff: +4 auf Treffer, Reichweite 1,5 m, eine Kreatur. Treffer: 5 (1W6+2) Wuchtschaden."
      },
      {
        "name": "Schwere Armbrust",
        "text": "Fernkampfwaffenangriff: +2 auf Treffer, Reichweite 30/120 m, ein Ziel. Treffer: 5 (1W10) Stichschaden."
      }
    ]
  },
