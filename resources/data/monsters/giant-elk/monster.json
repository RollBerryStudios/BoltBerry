  "traits": {
    "en": [
      {
        "name": "Charge",
        "text": "If the elk moves at least 20 ft. straight toward a target and then hits it with a ram attack on the same turn, the target takes an extra 7 (2d6) damage. If the target is a creature, it must succeed on a DC 14 Strength saving throw or be knocked prone."
      }
    ],
    "de": [
      {
        "name": "Sturmangriff",
        "text": "Wenn der Elch sich mindestens sechs Meter weit direkt auf ein Ziel zubewegt und es dann im selben Zug mit einem Rammbock-Angriff trifft, erleidet das Ziel zusätzlich 7 (2W6) Schaden. Wenn das Ziel eine Kreatur ist, muss es einen SG-14-Stärkerettungswurf bestehen, oder es wird umgestoßen."
      }
    ]
  },
  "actions": {
    "en": [
      {
        "name": "Ram",
        "text": "Melee Weapon Attack: +6 to hit, reach 10 ft., one target. Hit: 11 (2d6 + 4) bludgeoning damage."
      },
      {
        "name": "Hooves",
        "text": "Melee Weapon Attack: +6 to hit, reach 5 ft., one prone creature. Hit: 22 (4d8 + 4) bludgeoning damage."
      }
    ],
    "de": [
      {
        "name": "Hufe",
        "text": "Nahkampfwaffenangriff: +6 auf Treffer, Reichweite 1,5 m, eine liegende Kreatur. Treffer: 22 (4W8+4) Wuchtschaden."
      },
      {
        "name": "Rammbock",
        "text": "Nahkampfwaffenangriff: +6 auf Treffer, Reichweite 3 m, ein Ziel. Treffer: 11 (2W6+4) Wuchtschaden."
      }
    ]
  },
