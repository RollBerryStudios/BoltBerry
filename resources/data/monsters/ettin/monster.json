  "traits": {
    "en": [
      {
        "name": "Two Heads",
        "text": "The ettin has advantage on Wisdom (Perception) checks and on saving throws against being blinded, charmed, deafened, frightened, stunned, and knocked unconscious."
      },
      {
        "name": "Wakeful",
        "text": "When one of the ettin's heads is asleep, its other head is awake."
      }
    ],
    "de": [
      {
        "name": "Wachsam",
        "text": "Wenn einer der Köpfe des Ettins schläft, ist der andere Kopf wach."
      },
      {
        "name": "Zwei Köpfe",
        "text": "Der Ettin ist bei Weisheitswürfen (Wahrnehmung) und bei Rettungswürfen gegen die Zustände Betäubt, Bewusstlos, Bezaubert, Blind, Taub und Verängstigt im Vorteil."
      }
    ]
  },
  "actions": {
    "en": [
      {
        "name": "Multiattack",
        "text": "The ettin makes two attacks: one with its battleaxe and one with its morningstar."
      },
      {
        "name": "Battleaxe",
        "text": "Melee Weapon Attack: +7 to hit, reach 5 ft., one target. Hit: 14 (2d8 + 5) slashing damage."
      },
      {
        "name": "Morningstar",
        "text": "Melee Weapon Attack: +7 to hit, reach 5 ft., one target. Hit: 14 (2d8 + 5) piercing damage."
      }
    ],
    "de": [
      {
        "name": "Mehrfachangriff",
        "text": "Der Ettin führt zwei Angriffe aus: einen mit seiner Streitaxt und einen mit seinem Morgenstern."
      },
