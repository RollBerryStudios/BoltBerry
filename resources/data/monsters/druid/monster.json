      {
        "name": "2nd level (3 slots)",
        "text": "flame blade, moonbeam"
      }
    ],
    "de": [
      {
        "name": "Zaubern",
        "text": "Der Druide ist ein Zauberwirker des 4 Grades. Seine Zauberfertigkeit ist Weisheit (Zauberrettungswurf SG 12, +4 zum Treffen mit Zauberangriffen). Er hat die folgenden Druidenzauber vorbereitet:"
      },
      {
        "name": "Zaubertricks (nach Belieben)",
        "text": "Druidenkunst, Flammen erzeugen, Shillelagh"
      },
      {
        "name": "1. Grad (4 Zauberplätze)",
        "text": "Verstricken, Lange Schritte, Mit Tieren sprechen, Donnerwoge"
      },
      {
        "name": "2. Grad (3 Zauberplätze)",
        "text": "Tierbote, Rindenhaut"
      }
    ]
  },
