    "en": [
      {
        "name": "False Appearance",
        "text": "While the shrieker remains motionless, it is indistinguishable from an ordinary fungus."
      },
      {
        "name": "Shriek",
        "text": "When bright light or a creature is within 30 feet of the shrieker, it emits a shriek audible up to 300 feet away. The shrieker continues to shriek until the disturbance moves out of range, for 1d4 of its turns later."
      }
    ],
    "de": [
      {
        "name": "Falsches Erscheinungsbild",
        "text": "Solange der Kreischer sich nicht bewegt, ist er nicht von einem gewöhnlichen Pilz zu unterscheiden.  Reaktionen"
      },
      {
        "name": "Kreischen",
        "text": "Wenn sich helles Licht oder eine Kreatur im Abstand von bis zu neun Metern vom Kreischer befindet, stößt dieser ein Kreischen aus, das bis zu 90 Meter weit zu hören ist. Nachdem die Störung sich außer Reichweite bewegt hat, kreischt der Kreischer noch 1W4 seiner Züge lang weiter."
      }
    ]
  },
