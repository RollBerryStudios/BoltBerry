  "traits": {
    "en": [
      {
        "name": "Spider Climb",
        "text": "The spider can climb difficult surfaces, including upside down on ceilings, without needing to make an ability check."
      },
      {
        "name": "Web Sense",
        "text": "While in contact with a web, the spider knows the exact location of any other creature in contact with the same web."
      },
      {
        "name": "Web Walker",
        "text": "The spider ignores movement restrictions caused by webbing."
      }
    ],
    "de": [
      {
        "name": "Netzsinn",
        "text": "Solange die Spinne in Kontakt mit einem Spinnennetz ist, weiß sie genau, wo sich andere Kreaturen aufhalten, die in Kontakt mit demselben Netz sind."
      },
      {
        "name": "Netzwandler",
        "text": "Die Spinne ignoriert Bewegungseinschränkungen, die durch Netze verursacht werden."
      },
      {
        "name": "Spinnenklettern",
        "text": "Die Spinne kann an schwierigen Oberflächen klettern, auch kopfüber an der Decke, ohne Attributswürfe ausführen zu müssen."
      }
    ]
  },
  "actions": {
    "en": [
      {
        "name": "Bite",
        "text": "Melee Weapon Attack: +4 to hit, reach 5 ft., one creature. Hit: 1 piercing damage, and the target must succeed on a DC 9 Constitution saving throw or take 2 (1d4) poison damage."
      }
    ],
    "de": [
