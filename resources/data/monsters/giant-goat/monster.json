  "traits": {
    "en": [
      {
        "name": "Charge",
        "text": "If the goat moves at least 20 ft. straight toward a target and then hits it with a ram attack on the same turn, the target takes an extra 5 (2d4) bludgeoning damage. If the target is a creature, it must succeed on a DC 13 Strength saving throw or be knocked prone."
      },
      {
        "name": "Sure-Footed",
        "text": "The goat has advantage on Strength and Dexterity saving throws made against effects that would knock it prone."
      }
    ],
    "de": [
      {
        "name": "Sturmangriff",
        "text": "Wenn die Ziege sich mindestens sechs Meter weit direkt auf ein Ziel zubewegt und es dann im selben Zug mit einem Rammbock-Angriff trifft, erleidet das Ziel zusätzlich 5 (2W4) Wuchtschaden. Wenn das Ziel eine Kreatur ist, muss es einen SG-13-Stärkerettungswurf bestehen, oder es wird umgestoßen."
      },
      {
        "name": "Sicherer Tritt",
        "text": "Die Ziege ist bei Stärke- und Geschicklichkeitsrettungswürfen gegen Effekte, die sie umstoßen würden, im Vorteil."
      }
    ]
  },
  "actions": {
    "en": [
      {
        "name": "Ram",
        "text": "Melee Weapon Attack: +5 to hit, reach 5 ft., one target. Hit: 8 (2d4 + 3) bludgeoning damage."
      }
    ],
    "de": [
      {
        "name": "Rammbock",
        "text": "Nahkampfwaffenangriff: +5 auf Treffer, Reichweite 1,5 m, ein Ziel. Treffer: 8 (2W4+3) Wuchtschaden."
      }
    ]
  },
