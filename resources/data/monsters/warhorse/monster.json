    "en": [
      {
        "name": "Trampling Charge",
        "text": "If the horse moves at least 20 ft. straight toward a creature and then hits it with a hooves attack on the same turn, that target must succeed on a DC 14 Strength saving throw or be knocked prone. If the target is prone, the horse can make another attack with its hooves against it as a bonus action."
      }
    ],
    "de": [
      {
        "name": "Trampel-Sturmangriff",
        "text": "Wenn das Ross sich mindestens sechs Meter weit direkt auf eine Kreatur zubewegt und sie dann im selben Zug mit einem Hufangriff trifft, muss das Ziel einen SG-14-Stärkerettungswurf bestehen, oder es wird umgestoßen. Gegen ein liegendes Ziel kann das Ross als Bonusaktion einen weiteren Angriff mit seinen Hufen ausführen."
      }
    ]
  },
